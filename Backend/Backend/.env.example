NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/eduvision
ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-another-long-random-secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
FRONTEND_URL=http://localhost:3000
OPENAI_API_KEY=replace-with-your-openai-api-key
SUMMARY_MODEL=gpt-4.1-mini
QA_MODEL=gpt-4.1-mini
IMAGE_MODEL=gpt-image-1
VIDEO_MODEL=sora-2
REDIS_URL=redis://127.0.0.1:6379
PARSER_CONCURRENCY=2
PARSER_TIMEOUT_MS=120000
STORAGE_DRIVER=local
DOCUMENT_BUCKET=
AWS_REGION=us-east-1
DELETE_SOURCE_AFTER_PARSE=false
MAX_UPLOAD_MB=20
API_RATE_LIMIT_PER_15_MIN=300
MAX_DAILY_QA_TOKENS_PER_USER=100000
LOG_LEVEL=info
UPLOAD_STAGING_DIR=uploads/staging
